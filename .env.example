## Environment template for Shammah Real Estate (local + Render)
# Copy this file to `.env.local` for local development.
# Do NOT commit real secrets; keep this file as a template.

## Backend server
# Port your Express server listens on (Render usually sets this automatically)
# PORT=4000

## Cloudinary image storage (used by server.js)
# Replace the placeholders with your real values in `.env.local` or Render dashboard.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

## Frontend → API base URL (used by Vite/React)
# Public URL of your backend API. For local dev you can point at localhost,
# in production use your Render URL.
VITE_API_BASE_URL=

## Supabase configuration (backend uses this for persistent storage)
# You need a Supabase project with tables for `plots` and `news`.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE=

# Public key for the frontend (optional). Browser code uses this; it's safe to expose.
# Set at build time or runtime so `src/integrations/supabase/client.ts` can create a client.
VITE_SUPABASE_ANON_KEY=
# (alias: VITE_SUPABASE_PUBLISHABLE_KEY)

# Example values (DO NOT commit real secrets):
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
# VITE_API_BASE_URL=https://shammah-realestate-agency.onrender.com
